---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact" description="Contact Auritech PCs in Windsor, Ontario. Questions about custom PC builds, pricing, or pickup. Reach us at AuritechPcs@gmail.com.">
  <div style="padding:60px 24px 80px;max-width:1000px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:64px;">
      <div class="section-label">Get In Touch</div>
      <h1 class="section-title">Contact Us</h1>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.3fr;gap:48px;align-items:start;">
      <!-- Info -->
      <div>
        <div style="margin-bottom:40px;">
          <div class="section-label" style="margin-bottom:20px;">Contact Info</div>
          {[
            {icon:"📧",label:"Email",val:"AuritechPcs@gmail.com",href:"mailto:AuritechPcs@gmail.com"},
            {icon:"📞",label:"Motasem",val:"(519) 999-4609",href:"tel:+15199994609"},
            {icon:"📞",label:"Ahmed",val:"(506) 312-2991",href:"tel:+15063122991"},
            {icon:"📍",label:"Location",val:"Windsor, Ontario, Canada",href:null},
          ].map(c=>(
            <div style="display:flex;align-items:flex-start;gap:16px;margin-bottom:24px;">
              <div style="font-size:20px;margin-top:2px;">{c.icon}</div>
              <div>
                <div style="font-size:11px;letter-spacing:2px;color:var(--gold);opacity:0.7;text-transform:uppercase;margin-bottom:4px;">{c.label}</div>
                {c.href
                  ? <a href={c.href} style="font-size:15px;color:var(--text);">{c.val}</a>
                  : <div style="font-size:15px;color:var(--text);">{c.val}</div>
                }
              </div>
            </div>
          ))}
        </div>

        <div class="gold-line" style="margin-bottom:32px;"></div>

        <div class="section-label" style="margin-bottom:16px;">Follow Us</div>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {[
            {icon:`<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,handle:"@auritechpc",url:"https://instagram.com/auritechpc"},
            {icon:`<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.53.02C13.84 0 15.14.01 16.44 0c.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`,handle:"@auritech_pcs",url:"https://tiktok.com/@auritech_pcs"},
            {icon:`<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>`,handle:"AuritechPcs",url:"https://youtube.com/@AuritechPcs"},
          ].map(s=>(
            <a href={s.url} target="_blank" style="display:flex;align-items:center;justify-content:space-between;background:var(--surface);border:1px solid rgba(201,168,76,0.1);border-radius:10px;padding:14px 18px;transition:border-color 0.2s,color 0.2s;color:var(--text2);" class="social-link">
              <span style="display:flex;align-items:center;gap:10px;" set:html={s.icon + `<span style="font-size:13px;">${s.handle}</span>`}></span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="opacity:0.4;"><path d="M10 6v2H5v11h11v-5h2v7H3V6h7zm11-3v8h-2V6.413l-7.793 7.794-1.414-1.414L17.585 5H13V3h8z"/></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Form -->
      <div style="background:var(--surface);border:1px solid rgba(201,168,76,0.15);border-radius:16px;padding:40px;">
        <div style="font-family:'Cinzel',serif;font-size:16px;letter-spacing:1px;margin-bottom:28px;">Send a Message</div>
        <form id="contact-form">
          <div class="form-group"><label class="form-label">Name *</label><input type="text" class="form-input" id="c-name" required /></div>
          <div class="form-group"><label class="form-label">Email *</label><input type="email" class="form-input" id="c-email" required /></div>
          <div class="form-group"><label class="form-label">Phone</label><input type="tel" class="form-input" id="c-phone" placeholder="Optional" /></div>
          <div class="form-group">
            <label class="form-label">Are you local to Windsor, ON?</label>
            <select class="form-input" id="c-local" required>
              <option value="">Select one</option>
              <option value="Yes, Windsor / LaSalle area">Yes, Windsor / LaSalle area</option>
              <option value="Nearby but not Windsor">Nearby but not Windsor</option>
              <option value="No, will need shipping">No, will need shipping</option>
            </select>
          </div>
          <div class="form-group"><label class="form-label">Message *</label><textarea class="form-textarea" id="c-message" rows="5" required placeholder="What can we help you with?"></textarea></div>
          <button type="submit" class="btn btn-gold" style="width:100%;justify-content:center;" id="c-submit">Send Message</button>
        </form>
      </div>
    </div>
  </div>

  <style>
    .social-link:hover { border-color: rgba(201,168,76,0.4) !important; }
    @media (max-width:768px) {
      div[style*="grid-template-columns:1fr 1.3fr"] { grid-template-columns: 1fr !important; }
    }
  </style>

  <script>
    document.getElementById('contact-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('c-submit');
      const params = {
        name: document.getElementById('c-name').value,
        email: document.getElementById('c-email').value,
        phone: document.getElementById('c-phone').value,
        product_name: 'General Inquiry',
        price: '',
        is_local: document.getElementById('c-local').value || 'Not specified',
        message: document.getElementById('c-message').value,
      };
      btn.textContent = 'Sending...'; btn.disabled = true;
      try {
        const res = await fetch('/send-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'product_inquiry', honeypot: document.getElementById("_hp_")?.value || "", ...params }),
        });
        if (!res.ok) throw new Error();
        window.showToast('Message sent! We\'ll get back to you soon.', 'success');
        e.target.reset();
      } catch {
        window.showToast('Failed. Email us at AuritechPcs@gmail.com', 'error');
      } finally { btn.textContent = 'Send Message'; btn.disabled = false; }
    });
  </script>
</BaseLayout>
