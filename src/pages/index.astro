---
import BaseLayout from '../layouts/BaseLayout.astro';
const diamondBuilds = [
  { name: "Diamond Core", tier: "Entry", price: 1299, sale: 1499, color: "#a0a0a0",
    photo: "https://diamondpcs.ca/cdn/shop/files/core_1.png?v=1768243275",
    photos: ["https://diamondpcs.ca/cdn/shop/files/core_1.png?v=1768243275","https://diamondpcs.ca/cdn/shop/files/core_2.png?v=1768243287"],
    parts: [{item:"CPU",part:"Ryzen 5 5500"},{item:"GPU",part:"RTX 5060"},{item:"RAM",part:"16GB DDR4"},{item:"Storage",part:"1TB NVMe SSD"},{item:"Shipping",part:"$99 Flat Canada-wide"}] },
  { name: "Diamond Apex Plus", tier: "Mid-Range", price: 2539, sale: 2899, color: "#C9A84C",
    photo: "https://diamondpcs.ca/cdn/shop/files/infinit3.0.png?v=1768411876",
    photos: ["https://diamondpcs.ca/cdn/shop/files/infinit3.0.png?v=1768411876","https://diamondpcs.ca/cdn/shop/files/infiniti2.0.png?v=1768411876"],
    parts: [{item:"CPU",part:"Ryzen 7 7800X3D"},{item:"GPU",part:"RTX 5070"},{item:"RAM",part:"32GB DDR5"},{item:"Storage",part:"1TB NVMe SSD"},{item:"Shipping",part:"$99 Flat Canada-wide"}] },
  { name: "Diamond Elite RTX", tier: "Flagship", price: 3799, sale: 4299, color: "#e8d48a",
    photo: "https://diamondpcs.ca/cdn/shop/files/whte_corsair_3500x_d379b833-cf0a-43b0-ad4a-849fb54e45d6.png?v=1769716735",
    photos: ["https://diamondpcs.ca/cdn/shop/files/whte_corsair_3500x_d379b833-cf0a-43b0-ad4a-849fb54e45d6.png?v=1769716735","https://diamondpcs.ca/cdn/shop/files/updates_white_3500x_05691067-4a19-4111-a08c-0cd57c1f44fb.png?v=1769716719"],
    parts: [{item:"CPU",part:"Ryzen 7 9800X3D"},{item:"GPU",part:"RTX 5080"},{item:"RAM",part:"32GB DDR5"},{item:"Storage",part:"2TB NVMe SSD"},{item:"Shipping",part:"$99 Flat Canada-wide"}] },
];
---
<BaseLayout title="Home" description="The Gold Standard in Custom PCs. Windsor, Ontario.">

  <!-- Hero -->
  <section id="hero" style="min-height:92vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:80px 24px;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 30%,rgba(201,168,76,0.06) 0%,transparent 70%);pointer-events:none;"></div>
    <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:0.3;"></div>
    <!-- Floating gold orbs -->
    <div class="hero-orb" style="position:absolute;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,0.04) 0%,transparent 70%);top:-100px;right:-100px;animation:float1 8s ease-in-out infinite;pointer-events:none;"></div>
    <div class="hero-orb" style="position:absolute;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,0.03) 0%,transparent 70%);bottom:-50px;left:-80px;animation:float2 10s ease-in-out infinite;pointer-events:none;"></div>
    <div class="hero-orb" style="position:absolute;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,0.05) 0%,transparent 70%);top:30%;left:10%;animation:float3 6s ease-in-out infinite;pointer-events:none;"></div>

    <div class="fade-up" style="max-width:800px;position:relative;z-index:1;">
      <div id="hero-badge" style="display:inline-flex;align-items:center;gap:10px;background:rgba(201,168,76,0.07);border:1px solid rgba(201,168,76,0.22);border-radius:100px;padding:7px 20px;margin-bottom:28px;opacity:0;">
        <span style="width:7px;height:7px;border-radius:50%;background:var(--gold);display:inline-block;box-shadow:0 0 8px rgba(201,168,76,0.6);animation:badgePulse 2s ease-in-out infinite;flex-shrink:0;"></span>
        <span style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;">Windsor, Ontario &nbsp;·&nbsp; Est. 2024</span>
      </div>
      <h1 style="font-size:clamp(2.5rem,7vw,5rem);line-height:1.1;margin-bottom:24px;">
        <span id="hero-line1" style="display:block;opacity:0;">The Gold Standard</span>
        <span id="hero-line2" style="display:block;color:var(--gold);opacity:0;">in Custom PCs</span>
      </h1>
      <p id="hero-desc" style="font-size:clamp(15px,2vw,18px);color:var(--text2);max-width:560px;margin:0 auto 40px;line-height:1.8;opacity:0;">
        Every build crafted to dominate. We spec, build, and deliver performance machines, custom or pre-built, shipped across Canada or ready for local pickup.
      </p>
      <div id="hero-btns" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;opacity:0;">
        <a href="/custom-build" class="btn btn-gold">Build Your PC</a>
        <a href="/preconfigured" class="btn btn-outline">Browse Builds</a>
      </div>
      <div id="hero-stats" style="display:flex;gap:40px;justify-content:center;flex-wrap:wrap;margin-top:72px;padding-top:40px;border-top:1px solid rgba(201,168,76,0.12);opacity:0;">
        <div style="text-align:center;">
          <div style="font-family:'Cinzel',serif;font-size:clamp(1.2rem,3vw,1.8rem);color:var(--gold);font-weight:700;">100%</div>
          <div style="font-size:11px;letter-spacing:2px;color:var(--text3);text-transform:uppercase;margin-top:4px;">Stress Tested</div>
        </div>
        <div style="text-align:center;">
          <div style="font-family:'Cinzel',serif;font-size:clamp(1.2rem,3vw,1.8rem);color:var(--gold);font-weight:700;">48hr</div>
          <div style="font-size:11px;letter-spacing:2px;color:var(--text3);text-transform:uppercase;margin-top:4px;">Avg Build Time</div>
        </div>
        <div style="text-align:center;">
          <div id="stat-built" style="font-family:'Cinzel',serif;font-size:clamp(1.2rem,3vw,1.8rem);color:var(--gold);font-weight:700;">0</div>
          <div style="font-size:11px;letter-spacing:2px;color:var(--text3);text-transform:uppercase;margin-top:4px;">Builds Completed</div>
        </div>
        <div style="text-align:center;">
          <div style="font-family:'Cinzel',serif;font-size:clamp(1.2rem,3vw,1.8rem);color:var(--gold);font-weight:700;">Canada</div>
          <div style="font-size:11px;letter-spacing:2px;color:var(--text3);text-transform:uppercase;margin-top:4px;">Wide Delivery</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Auritech -->
  <section style="padding:80px 24px;max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:60px;">
      <div class="section-label">Why Choose Us</div>
      <h2 class="section-title">Built Different</h2>
    </div>
    <div class="stagger-children" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:24px;">
      <div class="feature-card" style="background:var(--surface);border:1px solid rgba(201,168,76,0.1);border-radius:var(--radius);padding:32px;transition:border-color 0.2s,transform 0.2s;">
        <div style="width:48px;height:48px;background:rgba(201,168,76,0.08);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3 style="font-size:16px;letter-spacing:1px;margin-bottom:10px;">Performance First</h3>
        <p style="font-size:14px;color:var(--text2);line-height:1.7;">Every component chosen for max FPS, thermals, and longevity. No filler parts, no shortcuts.</p>
      </div>
      <div class="feature-card" style="background:var(--surface);border:1px solid rgba(201,168,76,0.1);border-radius:var(--radius);padding:32px;transition:border-color 0.2s,transform 0.2s;">
        <div style="width:48px;height:48px;background:rgba(201,168,76,0.08);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <h3 style="font-size:16px;letter-spacing:1px;margin-bottom:10px;">Custom or Pre-Built</h3>
        <p style="font-size:14px;color:var(--text2);line-height:1.7;">Tell us your use case and budget and we build it. Or grab one of our ready-to-ship machines.</p>
      </div>
      <div class="feature-card" style="background:var(--surface);border:1px solid rgba(201,168,76,0.1);border-radius:var(--radius);padding:32px;transition:border-color 0.2s,transform 0.2s;">
        <div style="width:48px;height:48px;background:rgba(201,168,76,0.08);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3 style="font-size:16px;letter-spacing:1px;margin-bottom:10px;">Local to Windsor</h3>
        <p style="font-size:14px;color:var(--text2);line-height:1.7;">Come pick it up same day. No waiting weeks for shipping. Real people, real builds.</p>
      </div>
      <div class="feature-card" style="background:var(--surface);border:1px solid rgba(201,168,76,0.1);border-radius:var(--radius);padding:32px;transition:border-color 0.2s,transform 0.2s;">
        <div style="width:48px;height:48px;background:rgba(201,168,76,0.08);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        </div>
        <h3 style="font-size:16px;letter-spacing:1px;margin-bottom:10px;">Transparent Pricing</h3>
        <p style="font-size:14px;color:var(--text2);line-height:1.7;">You see every part, every cost. No mystery margins or bloatware bundled in.</p>
      </div>
    </div>
  </section>

  <!-- Auritech Builds — Same Day Pickup -->
  <section style="padding:80px 24px;max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:48px;">
      <div class="section-label">Built By Auritech</div>
      <h2 class="section-title">Same Day Pickup Builds</h2>
      <p style="font-size:15px;color:var(--text2);margin-top:12px;">Fully assembled, tested, and ready. Walk in and take it home — no wait.</p>
    </div>
    <div id="home-inventory" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,380px));gap:24px;justify-content:center;">
      <div style="text-align:center;padding:60px;color:var(--text3);font-size:14px;grid-column:1/-1;">Loading builds...</div>
    </div>
    <div style="text-align:center;margin-top:40px;">
      <a href="/inventory" class="btn btn-outline">View All Same Day Pickup →</a>
    </div>
  </section>

  <!-- Featured Diamond Builds -->
  <section style="padding:80px 24px;background:var(--surface);border-top:1px solid rgba(201,168,76,0.08);border-bottom:1px solid rgba(201,168,76,0.08);">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;flex-wrap:wrap;gap:16px;">
        <div>
          <div style="font-family:'Cinzel',serif;font-size:16px;letter-spacing:4px;color:var(--gold);text-transform:uppercase;margin-bottom:12px;">Auritech × Diamond PCs</div>
          <h2 class="section-title">Featured Builds</h2>
        </div>
        <a href="/preconfigured" class="btn btn-outline" style="font-size:11px;">View All →</a>
      </div>
      <div class="stagger-children" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;">
        {diamondBuilds.map(b=>(
          <div class="build-card" style="background:var(--surface2);border:1px solid rgba(201,168,76,0.12);border-radius:var(--radius);overflow:hidden;transition:all 0.2s;cursor:pointer;"
            onclick={`openBuildModal(${JSON.stringify({name:b.name,price:b.price,sale:b.sale,parts:b.parts,photos:b.photos,type:'preconfigured'})})`}>
            <div style="position:relative;height:220px;background:#0a0a0a;overflow:hidden;display:flex;align-items:center;justify-content:center;">
              <img src={b.photo} alt={b.name} loading="lazy" style="max-width:100%;max-height:100%;object-fit:contain;padding:16px;transition:transform 0.4s ease;" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'" />
              <div style={`position:absolute;top:12px;left:12px;display:flex;align-items:center;gap:6px;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);border:1px solid rgba(${b.color === '#e8d48a' ? '232,212,138' : b.color === '#C9A84C' ? '201,168,76' : '160,160,160'},0.25);border-radius:100px;padding:4px 12px;`}>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke={b.color} stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <span style={`font-size:9px;letter-spacing:2px;text-transform:uppercase;color:${b.color};`}>{b.tier}</span>
              </div>
            </div>
            <div style="padding:20px 24px 24px;">
              <div style="font-family:'Cinzel',serif;font-size:16px;letter-spacing:1px;margin-bottom:8px;">{b.name}</div>
              <div style="font-size:12px;color:var(--text2);margin-bottom:16px;line-height:1.6;">{b.parts.slice(0,3).map(p=>p.part).join(' · ')}</div>
              <div class="gold-line" style="margin-bottom:16px;"></div>
              <div style="display:flex;justify-content:space-between;align-items:flex-end;">
                <div>
                  <div style="font-size:11px;color:var(--text3);text-decoration:line-through;">${b.sale.toLocaleString()} CAD</div>
                  <div style="font-family:'Cinzel',serif;font-size:20px;color:var(--gold);">${b.price.toLocaleString()} CAD</div>
                </div>
                <span style="font-size:10px;color:var(--text3);letter-spacing:1px;">View details →</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:100px 24px;text-align:center;position:relative;overflow:hidden;border-top:1px solid rgba(201,168,76,0.1);">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(201,168,76,0.06) 0%,transparent 70%);pointer-events:none;"></div>
    <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:0.2;"></div>
    <div style="position:relative;z-index:1;max-width:600px;margin:0 auto;">
      <div style="width:64px;height:64px;background:rgba(201,168,76,0.08);border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 28px;border:1px solid rgba(201,168,76,0.15);">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><path d="M7 8h2m2 0h2m2 0h2" stroke-linecap="round"/></svg>
      </div>
      <div class="section-label">Ready to Build?</div>
      <h2 style="font-size:clamp(1.8rem,4vw,3rem);margin-bottom:16px;">Your Dream PC Starts Here</h2>
      <p style="font-size:15px;color:var(--text2);max-width:480px;margin:0 auto 36px;line-height:1.8;">Tell us your budget, use case, and priorities. We will build the perfect machine for you.</p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
        <a href="/custom-build" class="btn btn-gold">Start Your Custom Build</a>
        <a href="/contact" class="btn btn-outline">Contact Us</a>
      </div>
      <div style="display:flex;gap:32px;justify-content:center;margin-top:48px;flex-wrap:wrap;">
        <div style="display:flex;align-items:center;gap:8px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:12px;color:var(--text2);">Free consultation</span>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:12px;color:var(--text2);">$99 flat shipping Canada-wide</span>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:12px;color:var(--text2);">Stress-tested before delivery</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Build Detail Modal -->
  <div id="build-modal-overlay" onclick="if(event.target===this)closeBuildModal()" style="position:fixed;inset:0;background:rgba(0,0,0,0.88);backdrop-filter:blur(12px);z-index:2000;display:none;align-items:center;justify-content:center;padding:20px;">
    <div style="background:var(--surface);border:1px solid rgba(201,168,76,0.15);border-radius:16px;width:min(960px,96vw);max-height:90vh;overflow:hidden;display:flex;flex-direction:column;">
      <!-- Header -->
      <div style="display:flex;justify-content:space-between;align-items:center;padding:20px 28px;border-bottom:1px solid rgba(255,255,255,0.06);">
        <div>
          <div id="bm-name" style="font-family:'Cinzel',serif;font-size:19px;letter-spacing:1px;"></div>
          <div id="bm-price" style="font-size:15px;color:var(--gold);margin-top:3px;font-family:'Cinzel',serif;"></div>
        </div>
        <button onclick="closeBuildModal()" style="background:none;border:none;color:var(--text2);cursor:pointer;font-size:28px;line-height:1;padding:4px;">×</button>
      </div>
      <!-- Body -->
      <div style="display:flex;flex:1;overflow:hidden;min-height:0;">
        <!-- Left: photos -->
        <div id="bm-photo-col" style="flex:1;display:flex;flex-direction:column;padding:20px;gap:12px;min-width:0;">
          <div style="position:relative;flex:1;background:#0a0a0a;border-radius:10px;overflow:hidden;display:flex;align-items:center;justify-content:center;min-height:300px;">
            <img id="bm-main-img" src="" alt="" style="max-width:100%;max-height:420px;object-fit:contain;padding:16px;" />
            <button id="bm-prev" onclick="bmNav(-1)" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.6);border:1px solid rgba(201,168,76,0.3);color:var(--gold);border-radius:50%;width:38px;height:38px;cursor:pointer;font-size:18px;display:none;align-items:center;justify-content:center;">‹</button>
            <button id="bm-next" onclick="bmNav(1)" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.6);border:1px solid rgba(201,168,76,0.3);color:var(--gold);border-radius:50%;width:38px;height:38px;cursor:pointer;font-size:18px;display:none;align-items:center;justify-content:center;">›</button>
            <div id="bm-counter" style="position:absolute;bottom:10px;left:50%;transform:translateX(-50%);font-size:11px;color:var(--text3);background:rgba(0,0,0,0.5);padding:2px 12px;border-radius:100px;"></div>
          </div>
          <div id="bm-thumbs" style="display:flex;gap:8px;flex-wrap:wrap;"></div>
        </div>
        <!-- Right: specs + CTA -->
        <div style="width:280px;flex-shrink:0;border-left:1px solid rgba(255,255,255,0.06);padding:24px;display:flex;flex-direction:column;overflow-y:auto;">
          <div style="font-size:10px;letter-spacing:2px;color:var(--gold);opacity:0.6;margin-bottom:14px;text-transform:uppercase;">Specifications</div>
          <div id="bm-specs" style="flex:1;font-size:13px;"></div>
          <div id="bm-sale-row" style="margin-top:20px;display:none;">
            <div id="bm-sale-price" style="font-size:12px;color:var(--text3);text-decoration:line-through;"></div>
          </div>
          <div style="margin-top:12px;">
            <button id="bm-inquire-btn" class="btn btn-gold" style="width:100%;justify-content:center;font-size:11px;" onclick="handleInquireClick(this)">Inquire About This PC</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Inquiry Modal -->
  <div id="modal-overlay" class="modal-overlay" onclick="if(event.target===this)closeModal()">
    <div class="modal" role="dialog" aria-modal="true">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;">
        <h3 style="font-size:18px;letter-spacing:1px;">Inquire About Build</h3>
        <button onclick="closeModal()" style="background:none;border:none;color:var(--text2);cursor:pointer;font-size:24px;line-height:1;">×</button>
      </div>
      <div style="background:var(--surface2);border-radius:8px;padding:16px;margin-bottom:24px;border:1px solid rgba(201,168,76,0.15);">
        <div style="font-size:10px;letter-spacing:2px;color:var(--gold);opacity:0.7;margin-bottom:4px;">SELECTED BUILD</div>
        <div id="modal-product-name" style="font-family:'Cinzel',serif;font-size:16px;"></div>
        <div id="modal-product-price" style="font-size:14px;color:var(--gold);margin-top:4px;"></div>
      </div>
      <form id="modal-form">
        <input type="hidden" id="modal-type" />
        <div class="form-group">
          <label class="form-label">Your Name *</label>
          <input type="text" class="form-input" id="modal-name" required />
        </div>
        <div class="form-group">
          <label class="form-label">Email *</label>
          <input type="email" class="form-input" id="modal-email" required />
        </div>
        <div class="form-group">
          <label class="form-label">Phone</label>
          <input type="tel" class="form-input" id="modal-phone" placeholder="Optional" />
        </div>
        <div class="form-group">
          <label class="form-label">Are you local to Windsor, ON?</label>
          <select class="form-input" id="modal-local">
            <option value="">Not sure / prefer not to say</option>
            <option value="Yes — Windsor / LaSalle area">Yes — Windsor / LaSalle area</option>
            <option value="Nearby but not Windsor">Nearby but not Windsor</option>
            <option value="No — will need shipping">No — will need shipping</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Message</label>
          <textarea class="form-textarea" id="modal-message" placeholder="Any questions or notes..."></textarea>
        </div>
        <button type="submit" class="btn btn-gold" style="width:100%;justify-content:center;" id="modal-submit">Send Inquiry</button>
      </form>
    </div>
  </div>

  <style>
    .feature-card:hover { border-color: rgba(201,168,76,0.35) !important; }
    .build-card:hover { border-color: rgba(201,168,76,0.4) !important; }

    /* Hero entrance sequence */
    @keyframes fadeSlideDown { from { opacity:0; transform:translateY(-10px); } to { opacity:0.7; transform:translateY(0); } }
    @keyframes fadeSlideUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
    @keyframes heroGlow { 0%,100% { text-shadow: 0 0 30px rgba(201,168,76,0); } 50% { text-shadow: 0 0 40px rgba(201,168,76,0.15); } }

    @keyframes badgePulse { 0%,100% { box-shadow:0 0 6px rgba(201,168,76,0.5); } 50% { box-shadow:0 0 14px rgba(201,168,76,0.9); } }
    #hero-badge.show { animation: fadeSlideUp 0.6s ease forwards; }
    #hero-line1.show { animation: fadeSlideUp 0.7s ease forwards; }
    #hero-line2.show { animation: fadeSlideUp 0.7s 0.15s ease forwards, heroGlow 4s 1.5s ease-in-out infinite; }
    #hero-desc.show { animation: fadeSlideUp 0.6s ease forwards; }
    #hero-btns.show { animation: fadeSlideUp 0.6s ease forwards; }
    #hero-stats.show { animation: fadeSlideUp 0.6s ease forwards; }

    /* Floating orbs */
    @keyframes float1 { 0%,100% { transform:translate(0,0) scale(1); } 50% { transform:translate(-30px,20px) scale(1.1); } }
    @keyframes float2 { 0%,100% { transform:translate(0,0) scale(1); } 50% { transform:translate(20px,-30px) scale(1.05); } }
    @keyframes float3 { 0%,100% { transform:translate(0,0); } 50% { transform:translate(15px,25px); } }

    /* Enhanced CTA section */
    section:last-of-type { position: relative; }

    /* In-stock card image hover */
    .build-card [data-photos]:hover img { transform: scale(1.03); }
    .build-card [data-photos]:hover .img-hover-overlay { background: rgba(0,0,0,0.35) !important; }
    .build-card [data-photos]:hover .view-label { opacity: 1 !important; }

    /* Build detail modal */
    #build-modal-overlay.open { display:flex !important; }
    @media (max-width:640px) {
      #build-modal-overlay > div > div:last-child { flex-direction:column; }
      #build-modal-overlay > div > div:last-child > div:last-child { width:100%;border-left:none;border-top:1px solid rgba(255,255,255,0.06); }
    }
  </style>

  <script type="module">
    // ── HERO ENTRANCE SEQUENCE ──
    (function heroEntrance() {
      const badge = document.getElementById('hero-badge');
      const line1 = document.getElementById('hero-line1');
      const line2 = document.getElementById('hero-line2');
      const desc = document.getElementById('hero-desc');
      const btns = document.getElementById('hero-btns');
      const stats = document.getElementById('hero-stats');

      setTimeout(() => badge.classList.add('show'), 80);
      setTimeout(() => line1.classList.add('show'), 280);
      setTimeout(() => line2.classList.add('show'), 500);
      setTimeout(() => desc.classList.add('show'), 760);
      setTimeout(() => btns.classList.add('show'), 960);
      setTimeout(() => stats.classList.add('show'), 1160);
    })();

    import { initializeApp, getApps } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js';
    import { getDatabase, ref, onValue } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js';

    const firebaseConfig = {
      apiKey: "AIzaSyDA5XLxDqjzQb3toHkKpSxEVH9NW1GeD68",
      authDomain: "open-claw-b7e92.firebaseapp.com",
      databaseURL: "https://open-claw-b7e92-default-rtdb.firebaseio.com",
      projectId: "open-claw-b7e92",
      storageBucket: "open-claw-b7e92.firebasestorage.app",
      messagingSenderId: "733756283803",
      appId: "1:733756283803:web:0e9c75cd1c0afe94bb1f3e"
    };

    const app = getApps().length ? getApps()[0] : initializeApp(firebaseConfig);
    const db = getDatabase(app);

    function buildCard(b) {
      const photos = b.photos || [];
      const photoCount = photos.length;
      const price = b.listPrice || b.listingPrice || b.salePrice || '';
      const name = b.name || 'Custom Build';
      const partsArr = Array.isArray(b.parts) ? b.parts : [];
      const modalData = JSON.stringify({name, price, photos, parts: partsArr, type:'product'}).replace(/"/g,'&quot;');
      const img = photoCount
        ? `<div style="height:240px;background:#0a0a0a;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative;">
            <img src="${photos[0]}" alt="${name}" style="max-width:100%;max-height:100%;object-fit:contain;padding:12px;transition:transform 0.3s;" />
            ${photoCount > 1 ? `<div style="position:absolute;bottom:10px;right:10px;background:rgba(0,0,0,0.7);border-radius:100px;font-size:11px;padding:3px 10px;color:var(--text2);backdrop-filter:blur(4px);">+${photoCount-1} photos</div>` : ''}
          </div>`
        : `<div style="height:180px;background:var(--surface2);display:flex;align-items:center;justify-content:center;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text3)" stroke-width="1"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>`;
      return `<div class="build-card" style="background:var(--surface);border:1px solid rgba(201,168,76,0.12);border-radius:var(--radius);overflow:hidden;transition:all 0.2s;cursor:pointer;" onclick="openBuildModal(JSON.parse(this.dataset.build))" data-build="${modalData}">
        ${img}
        <div style="padding:24px;">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:12px;">
            <div style="font-family:'Cinzel',serif;font-size:16px;letter-spacing:1px;">${name}</div>
            <span style="font-size:9px;letter-spacing:1.5px;text-transform:uppercase;background:rgba(74,222,128,0.1);color:#4ade80;border:1px solid rgba(74,222,128,0.25);border-radius:100px;padding:3px 10px;white-space:nowrap;flex-shrink:0;">Same Day Pickup</span>
          </div>
          <div class="gold-line" style="margin-bottom:16px;"></div>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <div style="font-family:'Cinzel',serif;font-size:20px;color:var(--gold);">${price ? '$'+Number(price).toLocaleString()+' CAD' : 'Contact Us'}</div>
            <span style="font-size:10px;color:var(--text3);letter-spacing:1px;">View details →</span>
          </div>
        </div>
      </div>`;
    }

    onValue(ref(db, 'auritech_inventory_v2'), (snap) => {
      const data = snap.val();

      // Count total builds ever created
      let built = 0;
      if (data && data.builds) {
        data.builds.forEach(b => { if (b) built++; });
      }
      if (data && data.soldBuilds) {
        built += data.soldBuilds.length;
      }

      // Smooth eased count up
      function countUp(el, target) {
        if (!el || target === 0) { if(el) el.textContent = target; return; }
        const duration = 1500;
        const start = performance.now();
        function ease(t) { return t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2,3)/2; }
        function tick(now) {
          const elapsed = Math.min((now - start) / duration, 1);
          el.textContent = Math.round(ease(elapsed) * target);
          if (elapsed < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }

      countUp(document.getElementById('stat-built'), built);

      const container = document.getElementById('home-inventory');
      if (!data) { container.innerHTML = '<div style="text-align:center;padding:60px;color:var(--text3);grid-column:1/-1;">No PCs in stock right now. Check back soon!</div>'; return; }

      const listed = (data.builds || []).filter(b => b && b.status === 'listed');

      if (!listed.length) {
        container.innerHTML = '<div style="text-align:center;padding:60px;color:var(--text3);grid-column:1/-1;">No PCs in stock right now. Check back soon!</div>';
        return;
      }
      container.innerHTML = listed.slice(0,3).map(buildCard).join('');
    });

    // ── BUILD DETAIL MODAL ──
    let bmPhotos = [], bmIdx = 0, bmCurrent = {};
    window.openBuildModal = (data) => {
      bmCurrent = data;
      bmPhotos = data.photos || [];
      bmIdx = 0;
      const price = data.price;
      document.getElementById('bm-name').textContent = data.name || '';
      document.getElementById('bm-price').textContent = price ? '$' + Number(price).toLocaleString() + ' CAD' : 'Contact Us';
      // Sale price row
      const saleRow = document.getElementById('bm-sale-row');
      if (data.sale) {
        saleRow.style.display = 'block';
        document.getElementById('bm-sale-price').textContent = 'Was $' + Number(data.sale).toLocaleString() + ' CAD';
      } else { saleRow.style.display = 'none'; }
      // Specs
      const parts = data.parts || [];
      document.getElementById('bm-specs').innerHTML = parts.map(p =>
        `<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.05);">
          <span style="font-size:11px;letter-spacing:1px;color:var(--gold);opacity:0.7;text-transform:uppercase;">${p.item||''}</span>
          <span style="font-size:12px;color:var(--text);text-align:right;max-width:55%;">${p.part||''}</span>
        </div>`
      ).join('');
      // Inquire button
      const btn = document.getElementById('bm-inquire-btn');
      btn.dataset.name = data.name || '';
      btn.dataset.price = price ? '$' + Number(price).toLocaleString() + ' CAD' : '';
      btn.dataset.type = data.type || 'product';
      // Photos column
      const photoCol = document.getElementById('bm-photo-col');
      if (bmPhotos.length) {
        photoCol.style.display = 'flex';
        renderBM();
      } else {
        photoCol.style.display = 'none';
      }
      document.getElementById('build-modal-overlay').classList.add('open');
    };
    function renderBM() {
      document.getElementById('bm-main-img').src = bmPhotos[bmIdx] || '';
      const multi = bmPhotos.length > 1;
      document.getElementById('bm-prev').style.display = multi ? 'flex' : 'none';
      document.getElementById('bm-next').style.display = multi ? 'flex' : 'none';
      document.getElementById('bm-counter').textContent = multi ? `${bmIdx+1} / ${bmPhotos.length}` : '';
      document.getElementById('bm-thumbs').innerHTML = bmPhotos.map((p,i) =>
        `<img src="${p}" onclick="bmSet(${i})" style="width:64px;height:64px;object-fit:contain;padding:4px;border-radius:6px;cursor:pointer;border:2px solid ${i===bmIdx?'var(--gold)':'rgba(255,255,255,0.08)'};background:#0a0a0a;transition:border 0.15s;">`
      ).join('');
    }
    window.bmNav = (d) => { bmIdx = (bmIdx + d + bmPhotos.length) % bmPhotos.length; renderBM(); };
    window.bmSet = (i) => { bmIdx = i; renderBM(); };
    window.closeBuildModal = () => document.getElementById('build-modal-overlay').classList.remove('open');
    document.addEventListener('keydown', e => {
      if (document.getElementById('build-modal-overlay').classList.contains('open')) {
        if (e.key === 'ArrowLeft' && bmPhotos.length > 1) bmNav(-1);
        if (e.key === 'ArrowRight' && bmPhotos.length > 1) bmNav(1);
        if (e.key === 'Escape') closeBuildModal();
      }
    });

    // Modal
    window.handleInquireClick = (btn) => {
      document.getElementById('modal-product-name').textContent = btn.dataset.name;
      document.getElementById('modal-product-price').textContent = btn.dataset.price;
      document.getElementById('modal-type').value = btn.dataset.type;
      document.getElementById('modal-overlay').classList.add('open');
      setTimeout(() => document.getElementById('modal-name').focus(), 100);
    };
    window.closeModal = () => document.getElementById('modal-overlay').classList.remove('open');
    document.addEventListener('keydown', e => { if(e.key==='Escape') closeModal(); });

    document.getElementById('modal-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('modal-submit');
      const type = document.getElementById('modal-type').value;
      const params = {
        name: document.getElementById('modal-name').value,
        email: document.getElementById('modal-email').value,
        phone: document.getElementById('modal-phone').value,
        is_local: document.getElementById('modal-local').value || 'Not specified',
        message: document.getElementById('modal-message').value,
        build_name: document.getElementById('modal-product-name').textContent,
        product_name: document.getElementById('modal-product-name').textContent,
        price: document.getElementById('modal-product-price').textContent,
      };
      btn.textContent = 'Sending...'; btn.disabled = true;
      const emailType = type === 'preconfigured' ? 'preconfigured' : 'product_inquiry';
      try {
        const res = await fetch('/send-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: emailType, ...params }),
        });
        if (!res.ok) throw new Error();
        closeModal(); e.target.reset();
        window.showToast('Inquiry sent! We\'ll be in touch soon.', 'success');
      } catch {
        window.showToast('Failed to send. Email us at AuritechPcs@gmail.com', 'error');
      } finally { btn.textContent = 'Send Inquiry'; btn.disabled = false; }
    });
  </script>
</BaseLayout>
