---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Same Day Pickup Builds" description="Pre-built gaming PCs available for same-day pickup in Windsor, Ontario. Browse Auritech's in-stock computers. Walk in, pick it up, take it home today.">

  <div style="padding:60px 24px 80px;max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:64px;">
      <div class="section-label">Built By Auritech</div>
      <h1 class="section-title">Same Day Pickup Builds</h1>
      <p style="font-size:15px;color:var(--text2);max-width:520px;margin:0 auto;line-height:1.8;">
        Fully assembled and stress tested. Arrange a time, come pick it up, and take it home the same day.
      </p>
    </div>

    <div id="inventory-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(420px,1fr));gap:28px;">
      <div style="text-align:center;padding:80px;color:var(--text3);font-size:14px;grid-column:1/-1;">
        <div style="font-size:40px;margin-bottom:16px;">🖥️</div>
        Loading in-stock PCs...
      </div>
    </div>
  </div>

  <!-- Gallery Lightbox -->
  <div id="gallery-overlay" class="modal-overlay" onclick="if(event.target===this)closeGallery()" style="align-items:center;">
    <div style="background:var(--surface);border:1px solid rgba(201,168,76,0.15);border-radius:var(--radius);width:min(960px,96vw);max-height:90vh;overflow:hidden;display:flex;flex-direction:column;">
      <!-- Header -->
      <div style="display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:1px solid rgba(255,255,255,0.06);">
        <div>
          <div id="gallery-build-name" style="font-family:'Cinzel',serif;font-size:18px;letter-spacing:1px;"></div>
          <div id="gallery-price" style="font-size:14px;color:var(--gold);margin-top:2px;"></div>
        </div>
        <button onclick="closeGallery()" style="background:none;border:none;color:var(--text2);cursor:pointer;font-size:24px;line-height:1;">×</button>
      </div>
      <!-- Body -->
      <div style="display:flex;flex:1;overflow:hidden;min-height:0;">
        <!-- Left: photos -->
        <div style="flex:1;display:flex;flex-direction:column;padding:20px;gap:12px;min-width:0;">
          <!-- Main image with nav -->
          <div style="position:relative;flex:1;background:#111;border-radius:10px;overflow:hidden;display:flex;align-items:center;justify-content:center;min-height:280px;">
            <img id="gallery-main-img" src="" alt="" style="max-width:100%;max-height:400px;object-fit:contain;padding:16px;" />
            <button id="gallery-prev" onclick="galleryNav(-1)" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.6);border:1px solid rgba(201,168,76,0.3);color:var(--gold);border-radius:50%;width:36px;height:36px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;">‹</button>
            <button id="gallery-next" onclick="galleryNav(1)" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.6);border:1px solid rgba(201,168,76,0.3);color:var(--gold);border-radius:50%;width:36px;height:36px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;">›</button>
            <div id="gallery-counter" style="position:absolute;bottom:10px;left:50%;transform:translateX(-50%);font-size:11px;color:var(--text3);background:rgba(0,0,0,0.5);padding:2px 10px;border-radius:100px;"></div>
          </div>
          <!-- Thumbnails -->
          <div id="gallery-thumbs" style="display:flex;gap:8px;flex-wrap:wrap;"></div>
        </div>
        <!-- Right: specs + CTA -->
        <div style="width:260px;flex-shrink:0;border-left:1px solid rgba(255,255,255,0.06);padding:20px;display:flex;flex-direction:column;overflow-y:auto;">
          <div style="font-size:10px;letter-spacing:2px;color:var(--gold);opacity:0.6;margin-bottom:12px;text-transform:uppercase;">Specifications</div>
          <div id="gallery-specs" style="flex:1;"></div>
          <div style="margin-top:20px;">
            <button id="gallery-inquire-btn" class="btn btn-gold" style="width:100%;justify-content:center;font-size:11px;"
              onclick="handleInquireClick(this)">Inquire About This PC</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div id="modal-overlay" class="modal-overlay" onclick="if(event.target===this)closeModal()">
    <div class="modal" role="dialog" aria-modal="true">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;">
        <h3 style="font-size:18px;letter-spacing:1px;">Inquire About PC</h3>
        <button onclick="closeModal()" style="background:none;border:none;color:var(--text2);cursor:pointer;font-size:24px;line-height:1;">×</button>
      </div>
      <div style="background:var(--surface2);border-radius:8px;padding:16px;margin-bottom:24px;border:1px solid rgba(201,168,76,0.15);">
        <div style="font-size:10px;letter-spacing:2px;color:var(--gold);opacity:0.7;margin-bottom:4px;">INQUIRING ABOUT</div>
        <div id="modal-product-name" style="font-family:'Cinzel',serif;font-size:16px;"></div>
        <div id="modal-product-price" style="font-size:14px;color:var(--gold);margin-top:4px;"></div>
      </div>
      <form id="modal-form">
        <div class="form-group"><label class="form-label">Your Name *</label><input type="text" class="form-input" id="modal-name" required /></div>
        <div class="form-group"><label class="form-label">Email *</label><input type="email" class="form-input" id="modal-email" required /></div>
        <div class="form-group"><label class="form-label">Phone</label><input type="tel" class="form-input" id="modal-phone" placeholder="Optional" /></div>
        <div class="form-group">
          <label class="form-label">Are you local to Windsor, ON?</label>
          <select class="form-input" id="modal-local" required>
            <option value="">Select one</option>
            <option value="Yes, Windsor / LaSalle area">Yes, Windsor / LaSalle area</option>
            <option value="Nearby but not Windsor">Nearby but not Windsor</option>
            <option value="No, will need shipping">No, will need shipping</option>
          </select>
        </div>
        <div class="form-group"><label class="form-label">Message</label><textarea class="form-textarea" id="modal-message" placeholder="Any questions? Pick up or ship?"></textarea></div>
        <button type="submit" class="btn btn-gold" style="width:100%;justify-content:center;" id="modal-submit">Send Inquiry</button>
      </form>
    </div>
  </div>

  <style>
    .inv-card:hover { border-color: rgba(201,168,76,0.4) !important; transform: translateY(-3px); box-shadow: 0 12px 40px rgba(201,168,76,0.08); }
    .inv-card:hover .img-hover-overlay { background: rgba(201,168,76,0.04) !important; }
    #gallery-overlay { display:none; }
    #gallery-overlay.open { display:flex; }
    @media (max-width: 600px) {
      #gallery-overlay > div > div:last-child { flex-direction: column; }
      #gallery-overlay > div > div:last-child > div:last-child { width: 100%; border-left: none; border-top: 1px solid rgba(255,255,255,0.06); }
    }
  </style>

  <script type="module">
    import { initializeApp, getApps } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js';
    import { getDatabase, ref, onValue } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js';

    const firebaseConfig = {
      apiKey: "AIzaSyDA5XLxDqjzQb3toHkKpSxEVH9NW1GeD68",
      authDomain: "open-claw-b7e92.firebaseapp.com",
      databaseURL: "https://open-claw-b7e92-default-rtdb.firebaseio.com",
      projectId: "open-claw-b7e92",
      storageBucket: "open-claw-b7e92.firebasestorage.app",
      messagingSenderId: "733756283803",
      appId: "1:733756283803:web:0e9c75cd1c0afe94bb1f3e"
    };

    const app = getApps().length ? getApps()[0] : initializeApp(firebaseConfig);
    const db = getDatabase(app);
    let listedBuilds = [];

    function esc(s) {
      const d = document.createElement('div');
      d.textContent = s || '';
      return d.innerHTML;
    }
    function safeImgSrc(url) {
      try { return new URL(url).protocol === 'https:' ? url : ''; }
      catch { return ''; }
    }

    function specRow(label, value) {
      if (!value) return '';
      return `<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04);">
        <span style="font-size:11px;letter-spacing:1px;color:var(--gold);opacity:0.7;text-transform:uppercase;">${esc(label)}</span>
        <span style="font-size:12px;color:var(--text);text-align:right;max-width:60%;">${esc(value)}</span>
      </div>`;
    }

    function buildCard(b) {
      const photos = (b.photos || []).map(safeImgSrc).filter(Boolean);
      const partsArr = Array.isArray(b.parts) ? b.parts : [];
      const name = b.name || 'Custom Build';
      const price = b.listPrice || b.listingPrice || b.salePrice || '';
      const escapedName = esc(name);
      const photosJson = esc(JSON.stringify(photos));
      const partsHtml = partsArr.map(p => specRow(p.item || '', p.part || '')).join('');

      const imgSection = photos.length
        ? `<div style="position:relative;overflow:hidden;height:360px;background:#111;cursor:pointer;" onclick="openGallery(${b._idx})">
            <img src="${safeImgSrc(photos[0])}" alt="${escapedName}" style="width:100%;height:100%;object-fit:contain;padding:12px;" />
            ${photos.length > 1 ? `<div style="position:absolute;bottom:10px;right:10px;background:rgba(0,0,0,0.75);border-radius:100px;font-size:11px;padding:4px 12px;color:var(--text2);backdrop-filter:blur(4px);">+${photos.length-1} photos</div>` : ''}
            <div style="position:absolute;inset:0;background:rgba(201,168,76,0);transition:background 0.2s;" class="img-hover-overlay"></div>
          </div>`
        : `<div style="width:100%;height:360px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:48px;">🖥️</div>`;

      return `<div class="inv-card" style="background:var(--surface);border:1px solid rgba(201,168,76,0.12);border-radius:var(--radius);overflow:hidden;transition:all 0.2s;" data-photos="${photosJson}" data-name="${escapedName}" data-parts='${esc(JSON.stringify(partsArr))}' data-price="${esc(String(price))}">
        ${imgSection}
        <div style="padding:24px;">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:12px;">
            <div style="font-family:'Cinzel',serif;font-size:17px;letter-spacing:1px;">${escapedName}</div>
            <span style="font-size:9px;letter-spacing:1.5px;text-transform:uppercase;background:rgba(74,222,128,0.1);color:#4ade80;border:1px solid rgba(74,222,128,0.25);border-radius:100px;padding:3px 10px;white-space:nowrap;flex-shrink:0;">Same Day Pickup</span>
          </div>
          ${partsArr.length ? `<div style="margin-bottom:16px;">${partsHtml}</div>` : ''}
          ${b.description ? `<p style="font-size:13px;color:var(--text2);line-height:1.6;margin-bottom:16px;">${esc(b.description)}</p>` : ''}
          <div class="gold-line" style="margin-bottom:16px;"></div>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <div style="font-family:'Cinzel',serif;font-size:22px;color:var(--gold);">${price ? '$'+Number(price).toLocaleString()+' CAD' : 'Contact Us'}</div>
            <button class="btn btn-gold" style="font-size:10px;padding:10px 18px;"
              data-name="${escapedName}" data-price="${price ? '$'+Number(price).toLocaleString()+' CAD' : ''}"
              onclick="handleInquireClick(this)">Inquire</button>
          </div>
        </div>
      </div>`;
    }

    onValue(ref(db, 'auritech_inventory_v2'), (snap) => {
      const data = snap.val();
      const grid = document.getElementById('inventory-grid');
      if (!data) {
        grid.innerHTML = '<div style="text-align:center;padding:80px;color:var(--text3);grid-column:1/-1;"><div style="font-size:40px;margin-bottom:16px;">🖥️</div>No PCs in stock right now.<br/>Check back soon or <a href="/custom-build" style="color:var(--gold);">order a custom build</a>.</div>';
        return;
      }
      const listed = (data.builds || []).filter(b => b && b.status === 'listed');
      if (!listed.length) {
        grid.innerHTML = '<div style="text-align:center;padding:80px;color:var(--text3);grid-column:1/-1;"><div style="font-size:40px;margin-bottom:16px;">🖥️</div>No PCs in stock right now.<br/><a href="/custom-build" style="color:var(--gold);">Order a custom build</a> instead.</div>';
        return;
      }
      listedBuilds = listed;
      grid.innerHTML = listed.map((b, i) => buildCard({ ...b, _idx: i })).join('');
    });

    let galleryIdx = 0;
    let galleryPhotoIdx = 0;

    window.openGallery = (buildIdx) => {
      galleryIdx = buildIdx;
      galleryPhotoIdx = 0;
      renderGallery();
      document.getElementById('gallery-overlay').classList.add('open');
    };

    function renderGallery() {
      const b = listedBuilds[galleryIdx];
      const photos = b.photos || [];
      const partsArr = Array.isArray(b.parts) ? b.parts : [];
      const price = b.listPrice || b.listingPrice || b.salePrice || '';

      document.getElementById('gallery-build-name').textContent = b.name || 'Custom Build';
      document.getElementById('gallery-price').textContent = price ? '$' + Number(price).toLocaleString() + ' CAD' : 'Contact Us';

      // Main image
      const mainImg = document.getElementById('gallery-main-img');
      mainImg.src = photos[galleryPhotoIdx] || '';
      mainImg.style.display = photos.length ? 'block' : 'none';

      // Thumbnails
      const thumbs = document.getElementById('gallery-thumbs');
      thumbs.innerHTML = photos.map((p, i) => `
        <img src="${safeImgSrc(p)}" onclick="setGalleryPhoto(${i})"
          style="width:60px;height:60px;object-fit:contain;padding:4px;border-radius:6px;cursor:pointer;border:2px solid ${i === galleryPhotoIdx ? 'var(--gold)' : 'rgba(255,255,255,0.1)'};background:#111;transition:border 0.2s;" />
      `).join('');

      // Specs
      const specs = document.getElementById('gallery-specs');
      specs.innerHTML = partsArr.map(p => {
        if (!p.item && !p.part) return '';
        return `<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.05);">
          <span style="font-size:11px;letter-spacing:1px;color:var(--gold);opacity:0.7;text-transform:uppercase;">${esc(p.item || '')}</span>
          <span style="font-size:12px;color:var(--text);text-align:right;max-width:55%;">${esc(p.part || '')}</span>
        </div>`;
      }).join('');

      // Inquire button
      const btn = document.getElementById('gallery-inquire-btn');
      btn.dataset.name = b.name || 'Custom Build';
      btn.dataset.price = price ? '$' + Number(price).toLocaleString() + ' CAD' : '';

      // Nav arrows
      document.getElementById('gallery-prev').style.display = photos.length > 1 ? 'flex' : 'none';
      document.getElementById('gallery-next').style.display = photos.length > 1 ? 'flex' : 'none';
      document.getElementById('gallery-counter').textContent = photos.length > 1 ? `${galleryPhotoIdx + 1} / ${photos.length}` : '';
    }

    window.setGalleryPhoto = (i) => {
      galleryPhotoIdx = i;
      renderGallery();
    };

    window.galleryNav = (dir) => {
      const photos = (listedBuilds[galleryIdx] || {}).photos || [];
      galleryPhotoIdx = (galleryPhotoIdx + dir + photos.length) % photos.length;
      renderGallery();
    };

    window.closeGallery = () => document.getElementById('gallery-overlay').classList.remove('open');
    document.addEventListener('keydown', e => {
      if (document.getElementById('gallery-overlay').classList.contains('open')) {
        if (e.key === 'ArrowLeft') galleryNav(-1);
        if (e.key === 'ArrowRight') galleryNav(1);
        if (e.key === 'Escape') closeGallery();
      }
    });

    window.handleInquireClick = (btn) => {
      document.getElementById('modal-product-name').textContent = btn.dataset.name;
      document.getElementById('modal-product-price').textContent = btn.dataset.price;
      document.getElementById('modal-overlay').classList.add('open');
      setTimeout(() => document.getElementById('modal-name').focus(), 100);
    };
    window.closeModal = () => document.getElementById('modal-overlay').classList.remove('open');
    document.addEventListener('keydown', e => { if(e.key==='Escape') closeModal(); });

    document.getElementById('modal-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('modal-submit');
      const params = {
        name: document.getElementById('modal-name').value,
        email: document.getElementById('modal-email').value,
        phone: document.getElementById('modal-phone').value,
        is_local: document.getElementById('modal-local').value || 'Not specified',
        product_name: document.getElementById('modal-product-name').textContent,
        price: document.getElementById('modal-product-price').textContent,
        message: document.getElementById('modal-message').value,
      };
      btn.textContent = 'Sending...'; btn.disabled = true;
      try {
        const res = await fetch('/send-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'product_inquiry', honeypot: document.getElementById("_hp_")?.value || "", ...params }),
        });
        if (!res.ok) throw new Error();
        closeModal(); e.target.reset();
        window.showToast('Inquiry sent! We\'ll be in touch soon.', 'success');
      } catch {
        window.showToast('Failed. Email us at AuritechPcs@gmail.com', 'error');
      } finally { btn.textContent = 'Send Inquiry'; btn.disabled = false; }
    });
  </script>
</BaseLayout>
